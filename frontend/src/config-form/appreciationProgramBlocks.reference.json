{
  "meta": {
    "purpose": "Reference for /appreciation_config/options: merge `blocks` into `sections.blocks` (or use as `sections` if your API returns a bare array).",
    "config_options": ["Corporate Wise", "Category Wise", "Custom"],
    "required_root_keys": ["config_options"],
    "config_scope_visibility_values": ["always", "custom_only", "inherited_and_custom", "inherited_only"],
    "external_datasources_source_key_map": {
      "categories": "categories",
      "config_options": "config_options",
      "user_attributes": "user_attributes",
      "user_profile_attributes": "user_profile_attributes"
    }
  },
  "blocks": [
    {
      "title": "Configuration scope",
      "fields": [
        {
          "ui": { "width": "full" },
          "key": "inheritance",
          "type": "select",
          "label": "Award configuration follows",
          "default": "Custom",
          "options": { "source": "config_options" },
          "required": true,
          "placeholder": "Select…"
        }
      ],
      "layout": { "columns": 1 },
      "block_id": "config_scope",
      "description": "Corporate/Category vs Custom; pair with config_scope_visibility on each block.",
      "config_scope_visibility": "always"
    },
    {
      "title": "Basic Information",
      "fields": [
        {
          "ui": { "width": "half" },
          "key": "name",
          "type": "text",
          "label": "Program Name",
          "default": "",
          "required": true,
          "validation": { "max_length": 100, "min_length": 3 },
          "placeholder": "Enter program name"
        },
        {
          "ui": { "width": "half" },
          "key": "image",
          "type": "file",
          "label": "Program Image",
          "multiple": false,
          "required": true,
          "max_size_mb": 2
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "basic_information",
      "description": "Program name and display image (category from list URL when category mode is on).",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Giver Eligibility",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "mode",
          "type": "switch",
          "default": "all",
          "options": ["all", "rules"],
          "required": true
        },
        {
          "key": "rules",
          "type": "rule_builder",
          "config": {
            "add_rule_label": "Add Rule",
            "add_sub_rule_label": "Add Condition"
          },
          "visible_if": { "field": "mode", "equals": "rules" },
          "rule_schema": [
            {
              "key": "type",
              "type": "select",
              "options": ["user_attribute", "user_profile_attribute", "user_permission"]
            },
            {
              "key": "attribute",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "operator",
              "type": "select",
              "options": ["==", "!=", ">", "<", ">=", "<=", "in", "not_in"],
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "value",
              "type": "text",
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "profile_attribute",
              "type": "select",
              "options": { "source": "user_profile_attributes" },
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            },
            {
              "key": "profile_operator",
              "type": "select",
              "options": ["==", "!=", ">", "<", ">=", "<=", "in", "not_in"],
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            },
            {
              "key": "profile_value",
              "type": "text",
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            },
            {
              "key": "permission",
              "type": "text",
              "depends_on": { "field": "type", "equals": "user_permission" },
              "placeholder": "Enter permission name"
            }
          ]
        }
      ],
      "layout": { "columns": 1 },
      "block_id": "user_eligibility",
      "description": "Controls who can give an appreciation.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Block Rule",
      "fields": [
        {
          "key": "user_ids",
          "type": "multi_select_search",
          "label": "Blocked Users",
          "options": { "source": "users" },
          "required": false,
          "placeholder": "Search and select users"
        }
      ],
      "layout": { "columns": 1 },
      "block_id": "block_rule",
      "description": "Blocks specific users by their IDs.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Message Rules",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "isMandatory",
          "type": "switch",
          "label": "Mandatory",
          "default": false,
          "required": false
        },
        {
          "ui": { "width": "half" },
          "key": "minLimit",
          "type": "number",
          "label": "Minimum Length",
          "default": 0,
          "required": false
        },
        {
          "ui": { "width": "half" },
          "key": "maxLimit",
          "type": "number",
          "label": "Maximum Length",
          "default": 500,
          "required": false
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "message",
      "description": "Controls the appreciation message input: mandatory flag and character limits.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Recipient Count Limits",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "exact_enabled",
          "type": "switch",
          "label": "Exact Count",
          "default": false,
          "required": false
        },
        {
          "ui": { "width": "half" },
          "key": "exact",
          "type": "number",
          "label": "Exact Count",
          "required": false,
          "visible_if": { "field": "exact_enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "min",
          "type": "number",
          "label": "Minimum",
          "default": 1,
          "required": false,
          "visible_if": { "field": "exact_enabled", "equals": false }
        },
        {
          "ui": { "width": "half" },
          "key": "max",
          "type": "number",
          "label": "Maximum",
          "default": 50,
          "required": false,
          "visible_if": { "field": "exact_enabled", "equals": false }
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "recipient_count",
      "description": "Min/max/exact number of recipients per appreciation.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Receiver Eligibility (Award)",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "mode",
          "type": "switch",
          "default": "all",
          "options": ["all", "rules"]
        },
        {
          "key": "rules",
          "type": "rule_builder",
          "config": {
            "add_rule_label": "Add Rule",
            "add_sub_rule_label": "Add Condition"
          },
          "visible_if": { "field": "mode", "equals": "rules" },
          "rule_schema": [
            {
              "key": "type",
              "type": "select",
              "options": ["user_attribute", "user_profile_attribute"]
            },
            {
              "key": "attribute",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "operator",
              "type": "select",
              "options": ["==", "!=", ">", "<", ">=", "<=", "in", "not_in"],
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "value",
              "type": "text",
              "depends_on": { "field": "type", "equals": "user_attribute" }
            },
            {
              "key": "profile_attribute",
              "type": "select",
              "options": { "source": "user_profile_attributes" },
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            },
            {
              "key": "profile_operator",
              "type": "select",
              "options": ["==", "!=", ">", "<", ">=", "<=", "in", "not_in"],
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            },
            {
              "key": "profile_value",
              "type": "text",
              "depends_on": { "field": "type", "equals": "user_profile_attribute" }
            }
          ]
        }
      ],
      "layout": { "columns": 1 },
      "block_id": "receiver_award_eligibility",
      "description": "Checks if receiver is eligible for the selected award.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Giver → Receiver Eligibility",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "mode",
          "type": "switch",
          "default": "all",
          "options": ["all", "rules"]
        },
        {
          "key": "rules",
          "type": "rule_builder",
          "config": {
            "add_rule_label": "Add Rule",
            "add_sub_rule_label": "Add Condition"
          },
          "visible_if": { "field": "mode", "equals": "rules" },
          "rule_schema": [
            {
              "key": "type",
              "type": "select",
              "options": [
                "r_attr_vs_g_attr",
                "r_attr_vs_g_profile",
                "g_attr_vs_r_profile",
                "hierarchy",
                "in_approval_managers",
                "direct"
              ]
            },
            {
              "key": "r_attribute",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_attr" }
            },
            {
              "key": "g_attribute",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_attr" }
            },
            {
              "key": "operator_r_g_attr",
              "type": "select",
              "options": [
                "eq_cs",
                "neq_cs",
                "gt",
                "lt",
                "gte",
                "lte",
                "eq_ncs",
                "neq_ncs"
              ],
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_attr" }
            },
            {
              "key": "r_attribute_profile",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_profile" }
            },
            {
              "key": "g_profile",
              "type": "select",
              "options": { "source": "user_profile_attributes" },
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_profile" }
            },
            {
              "key": "operator_r_g_profile",
              "type": "select",
              "options": [
                "eq_cs",
                "neq_cs",
                "gt",
                "lt",
                "gte",
                "lte",
                "eq_ncs",
                "neq_ncs"
              ],
              "depends_on": { "field": "type", "equals": "r_attr_vs_g_profile" }
            },
            {
              "key": "g_attribute_profile",
              "type": "select",
              "options": { "source": "user_attributes" },
              "depends_on": { "field": "type", "equals": "g_attr_vs_r_profile" }
            },
            {
              "key": "r_profile",
              "type": "select",
              "options": { "source": "user_profile_attributes" },
              "depends_on": { "field": "type", "equals": "g_attr_vs_r_profile" }
            },
            {
              "key": "operator_g_r_profile",
              "type": "select",
              "options": [
                "eq_cs",
                "neq_cs",
                "gt",
                "lt",
                "gte",
                "lte",
                "eq_ncs",
                "neq_ncs"
              ],
              "depends_on": { "field": "type", "equals": "g_attr_vs_r_profile" }
            },
            {
              "key": "hierarchy_type",
              "type": "select",
              "options": [
                "manager_id",
                "manager_employeeID",
                "hrbp_manager",
                "bu_head"
              ],
              "depends_on": { "field": "type", "equals": "hierarchy" }
            },
            {
              "key": "direct_type",
              "type": "select",
              "options": [
                "manager_id",
                "manager_employeeID",
                "hrbp_manager",
                "bu_head"
              ],
              "depends_on": { "field": "type", "equals": "direct" }
            }
          ]
        }
      ],
      "layout": { "columns": 1 },
      "block_id": "giver_receiver_eligibility",
      "description": "Controls if giver can appreciate a receiver.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Tenure Rules",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "enabled",
          "type": "switch",
          "label": "Enable",
          "default": false
        },
        {
          "ui": { "width": "half" },
          "key": "months_min",
          "type": "number",
          "label": "Minimum Months",
          "default": 0,
          "required": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "months_max",
          "type": "number",
          "label": "Maximum Months",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "user_field_option",
          "type": "select",
          "label": "Tenure Based On",
          "options": ["service_referenced_date", "joining_date"],
          "required": false,
          "depends_on": { "field": "enabled", "equals": true },
          "placeholder": "Select an option"
        },
        {
          "ui": { "width": "half" },
          "key": "error_message",
          "type": "text",
          "label": "Error Message",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true },
          "placeholder": "Enter custom error message"
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "tenure",
      "description": "Minimum tenure (in months) required for the giver to appreciate.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Citation Character Limit",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "enabled",
          "type": "switch",
          "label": "Enable",
          "default": false
        },
        {
          "ui": { "position": "top-right" },
          "key": "isMandatory",
          "type": "switch",
          "label": "Mandatory",
          "default": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "min_length",
          "type": "number",
          "label": "Minimum Length",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "max_length",
          "type": "number",
          "label": "Maximum Length",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "full" },
          "key": "error_message",
          "type": "text",
          "label": "Error Message",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true },
          "placeholder": "Enter custom error message"
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "citation_limit",
      "description": "Maximum character length for the citation / reason field.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Media Upload Limits",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "enabled",
          "type": "switch",
          "label": "Enable",
          "default": false
        },
        {
          "ui": { "position": "top-right" },
          "key": "isMandatory",
          "type": "switch",
          "label": "Mandatory",
          "default": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "key": "audio",
          "type": "group",
          "label": "Audio",
          "fields": [
            { "ui": { "width": "half" }, "key": "min_count", "type": "number", "label": "Min", "default": 0 },
            { "ui": { "width": "half" }, "key": "max_count", "type": "number", "label": "Max", "default": 2 }
          ],
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "key": "image",
          "type": "group",
          "label": "Image",
          "fields": [
            { "ui": { "width": "half" }, "key": "min_count", "type": "number", "label": "Min", "default": 0 },
            { "ui": { "width": "half" }, "key": "max_count", "type": "number", "label": "Max", "default": 5 }
          ],
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "key": "video",
          "type": "group",
          "label": "Video",
          "fields": [
            { "ui": { "width": "half" }, "key": "min_count", "type": "number", "label": "Min", "default": 0 },
            { "ui": { "width": "half" }, "key": "max_count", "type": "number", "label": "Max", "default": 1 }
          ],
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "key": "document",
          "type": "group",
          "label": "Document",
          "fields": [
            { "ui": { "width": "half" }, "key": "min_count", "type": "number", "label": "Min", "default": 0 },
            { "ui": { "width": "half" }, "key": "max_count", "type": "number", "label": "Max", "default": 3 }
          ],
          "depends_on": { "field": "enabled", "equals": true }
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "mediaUpload",
      "description": "Min and max file counts per media type.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Greeting (Monetary Add-on)",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "enabled",
          "type": "switch",
          "label": "Enable",
          "default": false
        },
        {
          "ui": { "position": "top-right" },
          "key": "split",
          "type": "switch",
          "label": "Split Amount",
          "default": false,
          "visible_if": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "min_total",
          "type": "number",
          "label": "Minimum Total",
          "required": false,
          "visible_if": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "max_total",
          "type": "number",
          "label": "Maximum Total",
          "required": false,
          "visible_if": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "min_per_recipient",
          "type": "number",
          "label": "Min per Recipient",
          "required": false,
          "visible_if": { "field": "split", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "max_per_recipient",
          "type": "number",
          "label": "Max per Recipient",
          "required": false,
          "visible_if": { "field": "split", "equals": true }
        },
        {
          "ui": { "width": "full" },
          "key": "error_message",
          "type": "text",
          "label": "Error Message",
          "required": false,
          "visible_if": { "field": "enabled", "equals": true },
          "placeholder": "Enter custom error message"
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "greeting",
      "description": "Allows attaching a monetary greeting amount to a non-monetary appreciation.",
      "config_scope_visibility": "custom_only"
    },
    {
      "title": "Team Appreciation",
      "fields": [
        {
          "ui": { "position": "top-right" },
          "key": "enabled",
          "type": "switch",
          "label": "Enable",
          "default": false
        },
        {
          "ui": { "position": "top-right" },
          "key": "exact_enabled",
          "type": "switch",
          "label": "Exact Count",
          "default": false,
          "required": false,
          "depends_on": { "field": "enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "exact",
          "type": "number",
          "label": "Exact Count",
          "required": false,
          "depends_on": { "field": "enabled", "equals": true },
          "visible_if": { "field": "exact_enabled", "equals": true }
        },
        {
          "ui": { "width": "half" },
          "key": "min_receivers",
          "type": "number",
          "label": "Minimum",
          "default": 2,
          "depends_on": { "field": "enabled", "equals": true },
          "visible_if": { "field": "exact_enabled", "equals": false }
        },
        {
          "ui": { "width": "half" },
          "key": "max_receivers",
          "type": "number",
          "label": "Maximum",
          "depends_on": { "field": "enabled", "equals": true },
          "visible_if": { "field": "exact_enabled", "equals": false }
        }
      ],
      "layout": { "columns": 2 },
      "block_id": "team_appreciation",
      "description": "Controls team-level appreciation behavior.",
      "config_scope_visibility": "inherited_and_custom"
    }
  ]
}
